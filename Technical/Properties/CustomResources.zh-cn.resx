  <!-- LevelsLolo: class-level description -->
  <data name="LevelsLolo_Description" xml:space="preserve"><value>在图表上绘制 SpotGamma 风格的期权衍生水平线 (Combo, Large Gamma, Volatility Trigger, Call Wall, Put Wall, Zero Gamma)，信息提取自逗号分隔的文本。支持按类别配置线条样式，按等级 (Rank) 分配宽度和不透明度，0DTE 标签可选青色光晕，并为粗线等级中的高优先级 0DTE (LG/PW/CW) 提供点状高亮。</value></data>
 
  <!-- LevelsLolo: property display names -->
  <data name="LevelsLolo_RawText_DisplayName" xml:space="preserve"><value>原始文本</value></data>
  <data name="LevelsLolo_ClearTextNow_DisplayName" xml:space="preserve"><value>立即清除文本</value></data>
  <data name="LevelsLolo_RightAligned_DisplayName" xml:space="preserve"><value>文本右对齐</value></data>
  <data name="LevelsLolo_LastBarOnly_DisplayName" xml:space="preserve"><value>仅延伸至最后一根 K 线</value></data>
  <data name="LevelsLolo_OffsetX_DisplayName" xml:space="preserve"><value>X 轴偏移</value></data>
  <data name="LevelsLolo_OffsetY_DisplayName" xml:space="preserve"><value>Y 轴偏移</value></data>
  <data name="LevelsLolo_FontSize_DisplayName" xml:space="preserve"><value>字体大小</value></data>
  <data name="LevelsLolo_ThickMaxRank_DisplayName" xml:space="preserve"><value>粗线对应的等级上限</value></data>
  <data name="LevelsLolo_MediumMaxRank_DisplayName" xml:space="preserve"><value>中线对应的等级上限</value></data>
  <data name="LevelsLolo_ThickWidth_DisplayName" xml:space="preserve"><value>宽度（粗）</value></data>
